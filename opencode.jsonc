{
  "$schema": "https://opencode.ai/config.json",
  "snapshot": false,
  "permission": {
    "edit": "allow",
    "bash": "ask",
    "webfetch": "allow",
    "skill": {
      "*": "allow"
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "**/.DS_Store",
      ".opencode/snapshots/**",
      "**/.claude/**",
      "**/.cursor/**",
      "**/.agent/**",
      "ARCHIVE/**",
      "IMPORT/**",
      "DESK/**",
      "PLAYGROUND/**",
      "SCRATCH/**",
      "*.xlsx",
      "*.csv"
    ]
  },
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "instructions": [
    "./AGENTS.md",
    "./CLAUDE.md",
    "./DOCS/SKILL_INDEX.md",
    "./DOCS/storage-router.md",
    "./DOCS/brand-voice.md",
    "./DOCS/icp-summary.md",
    "./TASKS.md",
    "./.opencode/rules/00_flow_and_session_hygiene.md",
    "./.opencode/rules/file_operation_safety.md",
    "./.opencode/rules/design.md",
    "./.opencode/rules/marketing_amnesia_drift.md",
    "./.opencode/rules/marketing_batching.md",
    "./.opencode/rules/marketing_funnel_design.md",
    "./.opencode/rules/marketing_routing_stops.md",
    "./.opencode/rules/marketing_workflow_dod.md",
    "./.opencode/rules/sub-agents.md",
    "./.opencode/rules/60_orchestration_and_sub_agents.md",
    "./.opencode/rules/71_skill_routing.md",
    "./.opencode/rules/80_skill_routing_reading.md",
    "./.opencode/rules/80_skill_routing_viron.md",
    "./.opencode/rules/80_skill_philosophy_and_workflow.md",
    "./.opencode/rules/80_anatomy_of_complex_skill.md",
    "./.opencode/rules/80_skill_construction_law.md",
    "./DIRECTOR/PROMPTS/active/P00_BOOTSTRAP.md",
    "./DIRECTOR/PROMPTS/active/P01_SESSION_INIT.md",
    "./DIRECTOR/PROMPTS/active/P02_HANDOFF.md"
  ]
}
